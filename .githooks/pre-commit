#!/bin/sh

set -eu

if command -v pwsh >/dev/null 2>&1; then
  pwsh -NoProfile -ExecutionPolicy Bypass -File tools/pre_commit_format.ps1
elif command -v powershell >/dev/null 2>&1; then
  powershell -NoProfile -ExecutionPolicy Bypass -File tools/pre_commit_format.ps1
else
  echo "pre-commit: PowerShell is required to run the formatting hook." >&2
  exit 1
fi
